# Rehearse.io Environment Variables

# Backend
JWT_SECRET=your_jwt_secret_here
MONGO_URI=mongodb://admin:password@localhost:27017/rehearse?authSource=admin
MONGO_USERNAME=admin
MONGO_PASSWORD=your_mongo_password_here
PORT=9000
NODE_ENV=development

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=your_ai_service_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
STT_BACKEND=local           # "local" | "groq" | "openai" | "auto" (default: local)
STT_LOCAL_MODEL=distil-large-v3  # faster-whisper model (local backend only)
STT_LOCAL_DEVICE=cpu        # "cpu" or "cuda"

# Frontend (built at compile time)
VITE_API_URL=http://localhost:9000

# Rate Limiting
RATE_MAX=1000
AUTH_RATE_MAX=10
