{
  "name": "rehearse.io",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:backend": "cd backend && npm start",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:ai": "cd ai-service/app && uvicorn main:app --reload",
    "dev:db": "docker compose up -d",
    "dev": "npm run dev:db && concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:ai\"",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install",
    "install:ai": "cd ai-service && pip install -r requirements.txt",
    "setup": "npm run install:backend && npm run install:frontend && npm run install:ai",
    "setup:env": "cd backend && cp example.env .env",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shrijit37/Rehearse.io.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/shrijit37/Rehearse.io/issues"
  },
  "homepage": "https://github.com/shrijit37/Rehearse.io#readme",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
